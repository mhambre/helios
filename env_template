# Helios - Environment Variables

## DO NOT TOUCH
__ENV_FULL_PATH="$(readlink -f "${BASH_SOURCE[0]}")"

## General Variables
PROJECT=helios
ARCH="$(uname -m)"
PROJECT_DIR="$(dirname -- "${__ENV_FULL_PATH}")"

## Build Variables
GRUB_TARGET=${ARCH}-efi
RUST_TARGET=${ARCH}-${PROJECT}
RUST_TARGET_JSON=${PROJECT_DIR}/template/${ARCH}-${PROJECT}.json
BUILD_DIR=${PROJECT_DIR}/build
ISO_BUILD_DIR=${BUILD_DIR}/iso

## Run Variables
QEMU_MEM=128M
QEMU_EXECUTABLE=qemu-system-${ARCH}
