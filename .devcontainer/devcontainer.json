{
  "name": "Helios Development",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--device=/dev/kvm",
    "--cap-add=NET_ADMIN",
    "--device=/dev/loop-control"
  ],
  "mounts": [
    "source=helios-cargo-registry,target=/home/vscode/.cargo/registry,type=volume",
    "source=helios-cargo-git,target=/home/vscode/.cargo/git,type=volume",
    "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.ssh/config,target=/home/vscode/.ssh/config,type=bind,consistency=cached,readonly",
    "source=${localEnv:HOME}/.ssh/known_hosts,target=/home/vscode/.ssh/known_hosts,type=bind,consistency=cached,readonly",
    "source=${localEnv:HOME}/.ssh/keys,target=/home/vscode/.ssh/keys,type=bind,consistency=cached,readonly"
  ],
  "forwardPorts": [
    1234
  ],
  "portsAttributes": {
    "1234": {
      "label": "QEMU GDB",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "serayuzgur.crates",
        "nefrob.vscode-just-syntax",
        "vadimcn.vscode-lldb",
        "ms-vscode.makefile-tools",
        "tomrijndorp.find-it-faster",
        "tamasfe.even-better-toml",
        "github.vscode-github-actions",
        "timonwong.shellcheck",
        "foxundermoon.shell-format",
        "editorconfig.editorconfig",
        "zixuanwang.linkerscript"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "rust-analyzer.checkOnSave": true,
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.check.extraArgs": [
          "--all-targets",
          "--all-features"
        ],
        "[shellscript]": {
          "editor.defaultFormatter": "foxundermoon.shell-format",
          "editor.formatOnSave": true
        },
        "shellcheck.enable": true,
        "shellcheck.run": "onSave",
        "shellcheck.executablePath": "shellcheck",
        "shellformat.path": "shfmt",
        "shellformat.useEditorConfig": true,
        "shellformat.flag": "-i 2 -ci -sr"
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "remoteUser": "vscode"
}